{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.spialr.com"
        }
      ],
      "destination": "https://spialr.com/:path*",
      "permanent": true
    }
  ]
}
